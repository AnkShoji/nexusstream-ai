{
  "entities": {
    "Transaction": {
      "title": "Sales Transaction",
      "description": "Represents a single purchase event in the system.",
      "type": "object",
      "properties": {
        "productId": { "type": "string", "description": "Unique identifier for the product" },
        "productName": { "type": "string" },
        "price": { "type": "number", "description": "Unit price of the product" },
        "quantity": { "type": "number" },
        "total": { "type": "number", "description": "Total price of the transaction" },
        "category": { "type": "string", "enum": ["Electronics", "Fashion", "Home", "Sports", "Beauty"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "processed": { "type": "boolean", "description": "Whether the background worker has processed this" },
        "isAnomaly": { "type": "boolean", "description": "Flag set by statistical engine if price/volume is irregular" }
      },
      "required": ["productId", "price", "quantity", "total", "category", "timestamp"]
    },
    "Summary": {
      "title": "Business Dashboard Summary",
      "description": "Aggregated metrics for the dashboard.",
      "type": "object",
      "properties": {
        "totalRevenue": { "type": "number" },
        "transactionCount": { "type": "number" },
        "categoryRevenue": { "type": "object", "description": "Mapping of category names to total revenue" },
        "lastUpdated": { "type": "string", "format": "date-time" },
        "businessMetrics": {
          "type": "object",
          "properties": {
            "ltv": { "type": "number" },
            "conversionRate": { "type": "number" },
            "retentionRate": { "type": "number" },
            "churnRisk": { "type": "number" }
          }
        }
      }
    }
  },
  "firestore": {
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Incoming raw purchase events."
    },
    "/summaries/{summaryId}": {
      "schema": "Summary",
      "description": "Real-time aggregated metrics."
    }
  }
}
